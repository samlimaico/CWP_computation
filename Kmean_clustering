# CONFIG - change only this section
crop_name  = 'Redgram'
years      = [2019]  # add more years as they become available
max_k      = 10      # maximum k to test in elbow method
output_root = r'C:\Users\limai\Desktop\KU LEUVEN\THESIS\output'
shapefile   = r'C:\Users\limai\Desktop\KU LEUVEN\THESIS\NLBC_Command\6_commands_complete.shp'

# Input folders
aeti_folder  = Path(output_root) / f'1_AETI_{crop_name}_masked'
yield_folder = Path(output_root) / f'1_CropYield_{crop_name}_masked'
cwp_folder   = Path(output_root) / f'1_CWP_{crop_name}_masked'


# Output folders
cluster_folder = Path(output_root) / f'2_Clusters_{crop_name}'
elbow_folder   = cluster_folder / 'elbow_plots'
stats_folder   = cluster_folder / 'statistics'
cluster_folder.mkdir(parents=True, exist_ok=True)
elbow_folder.mkdir(parents=True, exist_ok=True)
stats_folder.mkdir(parents=True, exist_ok=True)

for year in years:
    print(f'\n{"="*60}')
    print(f'Processing {year} — {crop_name.upper()}')
    print(f'{"="*60}')

    # File paths
    aeti_path  = aeti_folder  / f'AETI_{year}.tif'
    yield_path = yield_folder / f'Yield_{year}.tif'
    cwp_path   = cwp_folder   / f'CWP_{year}.tif'

    missing = [p for p in [aeti_path, yield_path, cwp_path] if not p.exists()]
    if missing:
        print(f'  Skipping {year}: missing files:')
        for m in missing:
            print(f'    {m}')
        continue

    # ── Load rasters ──────────────────────────────────────────
    print(f'  Loading rasters...')
    with rasterio.open(aeti_path) as src:
        aeti = src.read(1).astype(np.float32)
        
        profile = src.profile
        shape = aeti.shape

    with rasterio.open(yield_path) as src:
        yld = src.read(1).astype(np.float32)

    with rasterio.open(cwp_path) as src:
        cwp = src.read(1).astype(np.float32)

    # Remove pixels with unrealistically low values
    yld[yld   < 100] = np.nan
    aeti[aeti < 10]  = np.nan
    cwp[cwp   < 0.1] = np.nan

    # ── Stack and find valid pixels ───────────────────────────
    stack = np.stack([aeti, yld], axis=-1)  # (rows, cols, 2)
    flat  = stack.reshape(-1, 2)                  # (pixels, 2)

    valid_mask   = ~np.any(np.isnan(flat), axis=1)
    valid_pixels = flat[valid_mask]

    print(f'  Valid pixels: {valid_pixels.shape[0]:,} / {flat.shape[0]:,}')

    if valid_pixels.shape[0] < max_k:
        print(f'  Not enough valid pixels, skipping.')
        continue

    # ── Standardize ───────────────────────────────────────────
    scaler = StandardScaler()
    scaled = scaler.fit_transform(valid_pixels)

    # ── Elbow method ──────────────────────────────────────────
    print(f'  Computing elbow curve (k=1 to {max_k})...')
    inertias = []

    for k in range(1, max_k + 1):
        km = KMeans(n_clusters=k, random_state=42, n_init=10)
        km.fit(scaled)
        inertias.append(km.inertia_)
        print(f'    k={k} | inertia={km.inertia_:.2f}')

    # Plot elbow curve
    fig, ax = plt.subplots(figsize=(9, 5))
    ax.plot(range(1, max_k + 1), inertias, 'bo-', linewidth=2, markersize=8)
    ax.set_xlabel('Number of clusters (k)', fontsize=12)
    ax.set_ylabel('Inertia (within-cluster sum of squares)', fontsize=12)
    ax.set_title(f'Elbow Method — {crop_name.upper()} {year}', fontsize=14)
    ax.grid(True, alpha=0.3)
    for i, (k, inertia) in enumerate(zip(range(1, max_k + 1), inertias)):
        ax.annotate(f'{inertia:.0f}', (k, inertia), textcoords='offset points',
                    xytext=(0, 10), ha='center', fontsize=8)
    plt.tight_layout()
    elbow_path = elbow_folder / f'elbow_{crop_name}_{year}.png'
    plt.savefig(elbow_path, dpi=150, bbox_inches='tight')
    plt.show()
    plt.close()
    print(f'  Elbow plot saved: {elbow_path}')

    # ── Ask user for optimal k ────────────────────────────────
    while True:
        try:
            k = int(input(f'\n  Look at the elbow plot and enter optimal k for {year}: '))
            if 1 <= k <= max_k:
                break
            print(f'  Please enter a number between 1 and {max_k}.')
        except ValueError:
            print('  Please enter a valid integer.')

    # ── Run K-Means with chosen k ─────────────────────────────
    print(f'\n  Running K-Means with k={k}...')
    km_final = KMeans(n_clusters=k, random_state=42, n_init=10)
    labels   = km_final.fit_predict(scaled)
    
    # ── Reconstruct cluster raster ────────────────────────────
    cluster_map = np.full(flat.shape[0], np.nan, dtype=np.float32)
    cluster_map[valid_mask] = labels + 1  # clusters start from 1
    cluster_raster = cluster_map.reshape(shape)
    

    # ── Cluster statistics ────────────────────────────────────
    print(f'\n  Cluster statistics for {year} (k={k}):')
    print(f'  {"Cluster":<10} {"Count":>8} {"AETI mean":>12} {"Yield mean":>12}')
    print(f'  {"-"*48}')

    stats_rows = []
    for c in range(k):
        mask_c    = labels == c
        vals      = valid_pixels[mask_c]

        # CWP stats per cluster (not used in clustering, just for reporting)
        cwp_flat  = cwp.flatten()
        cwp_mask  = cluster_map.reshape(-1) == (c + 1)
        cwp_valid = cwp_flat[cwp_mask & ~np.isnan(cwp_flat)]

        print(f'  Cluster {c+1:<3} {mask_c.sum():>8,} '
              f'{vals[:,0].mean():>12.1f} '
              f'{vals[:,1].mean():>12.1f}')
        stats_rows.append({
            'Year':               year,
            'Cluster':            c + 1,
            'N_pixels':           int(mask_c.sum()),
            'AETI_mean (mm)':     round(float(vals[:,0].mean()), 1),
            'AETI_std':           round(float(vals[:,0].std()),  1),
            'Yield_mean (kg/ha)': round(float(vals[:,1].mean()), 1),
            'Yield_std':          round(float(vals[:,1].std()),  1),
            'CWP_mean (kg/m³)':   round(float(np.nanmean(cwp_valid)), 3) if len(cwp_valid) > 0 else np.nan,
            'CWP_std':            round(float(np.nanstd(cwp_valid)),  3) if len(cwp_valid) > 0 else np.nan,
        })

    # Save statistics to CSV
    stats_df = pd.DataFrame(stats_rows)
    stats_path = stats_folder / f'ClusterStats_{crop_name}_{year}_k{k}.csv'
    stats_df.to_csv(stats_path, index=False)
    print(f'\n  Statistics saved: {stats_path}')
    
    # Save cluster raster
    profile.update(dtype='float32', nodata=np.nan, count=1)
    out_path = cluster_folder / f'Clusters_{crop_name}_{year}_k{k}.tif'
    with rasterio.open(out_path, 'w', **profile) as dst:
        dst.write(cluster_raster, 1)
    print(f'  Cluster raster saved: {out_path}')


print(f'\n{"="*60}')
print('All done! Outputs saved to:')
print(f'  Cluster rasters:  {cluster_folder}')
print(f'  Elbow plots:      {elbow_folder}')
print(f'  Statistics CSVs:  {stats_folder}')

