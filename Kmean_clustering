# Load rasters clipped to shapefile extent
def load_clipped(path, gdf):
    with rasterio.open(path) as src:
        masked, transform = rasterio.mask.mask(src, gdf.geometry, crop=True, nodata=np.nan)
        data = masked[0].astype(np.float32)
        nodata = src.nodata
        if nodata is not None:
            data[data == nodata] = np.nan
        nrows, ncols = data.shape
        left   = transform.c
        top    = transform.f
        right  = left + ncols * transform.a
        bottom = top  + nrows * transform.e
        extent = [left, right, bottom, top]
    return data, extent

